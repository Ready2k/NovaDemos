{
  "Version": "2019-10-30",
  "StartAction": "set-logging",
  "Metadata": {
    "entryPointPosition": { "x": 60, "y": 115 },
    "ActionMetadata": {
      "set-logging":       { "position": { "x": 60,  "y": 115 } },
      "play-hold":         { "position": { "x": 260, "y": 115 } },
      "transfer-to-chime": { "position": { "x": 460, "y": 115 } },
      "play-returning":    { "position": { "x": 660, "y": 115 } },
      "set-queue":         { "position": { "x": 860, "y": 115 } },
      "transfer-to-queue": { "position": { "x": 1060, "y": 115 } },
      "disconnect-fallback": { "position": { "x": 1060, "y": 315 } }
    },
    "name": "SIP-SBC-Transfer",
    "description": "Transfer PSTN caller to the Nova 2 Sonic SBC via Amazon Chime SDK Voice Connector. On return/failure, route to human agent queue."
  },
  "Actions": [
    {
      "Identifier": "set-logging",
      "Type": "UpdateContactEventHooks",
      "Parameters": {
        "Logging": { "Behavior": "Enable" }
      },
      "Transitions": {
        "NextAction": "play-hold",
        "Errors": [{ "NextAction": "play-hold", "ErrorType": "NoMatchingError" }]
      }
    },
    {
      "Identifier": "play-hold",
      "Type": "MessageParticipant",
      "Parameters": {
        "Text": "Please hold while we connect you to your banking assistant.",
        "TextToSpeechType": "text",
        "VoiceId": "Amy"
      },
      "Transitions": {
        "NextAction": "transfer-to-chime",
        "Errors": [{ "NextAction": "transfer-to-chime", "ErrorType": "NoMatchingError" }]
      }
    },
    {
      "Identifier": "transfer-to-chime",
      "Type": "TransferContactToPhoneNumber",
      "Parameters": {
        "PhoneNumber": {
          "Type": "ValueOf",
          "ValueOf": "$.Attributes.ChimeVcDID",
          "StaticValue": "+12015551234"
        },
        "CallerId": {
          "Type": "ValueOf",
          "ValueOf": "$.CustomerEndpoint.Address"
        }
      },
      "Transitions": {
        "NextAction": "play-returning",
        "Errors": [
          { "NextAction": "play-returning", "ErrorType": "NoMatchingError" },
          { "NextAction": "play-returning", "ErrorType": "CallFailed" },
          { "NextAction": "play-returning", "ErrorType": "InvalidPhoneNumber" }
        ]
      }
    },
    {
      "Identifier": "play-returning",
      "Type": "MessageParticipant",
      "Parameters": {
        "Text": "Thank you for speaking with our banking assistant. Let me connect you with an agent who can help with anything further.",
        "TextToSpeechType": "text",
        "VoiceId": "Amy"
      },
      "Transitions": {
        "NextAction": "set-queue",
        "Errors": [{ "NextAction": "set-queue", "ErrorType": "NoMatchingError" }]
      }
    },
    {
      "Identifier": "set-queue",
      "Type": "UpdateContactTargetQueue",
      "Parameters": {
        "Queue": {
          "Type": "Value",
          "QueueId": "REPLACE_WITH_YOUR_BASIC_QUEUE_ARN"
        }
      },
      "Transitions": {
        "NextAction": "transfer-to-queue",
        "Errors": [{ "NextAction": "disconnect-fallback", "ErrorType": "NoMatchingError" }]
      }
    },
    {
      "Identifier": "transfer-to-queue",
      "Type": "TransferContactToQueue",
      "Parameters": {},
      "Transitions": {
        "NextAction": "disconnect-fallback",
        "Errors": [
          { "NextAction": "disconnect-fallback", "ErrorType": "NoMatchingError" },
          { "NextAction": "disconnect-fallback", "ErrorType": "QueueAtCapacity" }
        ]
      }
    },
    {
      "Identifier": "disconnect-fallback",
      "Type": "DisconnectParticipant",
      "Parameters": {},
      "Transitions": {}
    }
  ]
}
