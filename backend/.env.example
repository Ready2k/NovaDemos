# AWS Configuration for Amazon Bedrock Nova 2 Sonic
# Copy this file to .env and fill in your actual values

# AWS Region where Bedrock is available (e.g., us-east-1, us-west-2)
NOVA_AWS_REGION=us-east-1

# AWS Credentials (or use IAM role if running on EC2/ECS)
NOVA_AWS_ACCESS_KEY_ID=your_access_key_here
NOVA_AWS_SECRET_ACCESS_KEY=your_secret_key_here
# Session Token (Required if using temporary credentials, e.g. from SSO)
NOVA_AWS_SESSION_TOKEN=

# Nova 2 Sonic Model ID (latest version released December 2025)
NOVA_SONIC_MODEL_ID=amazon.nova-2-sonic-v1:0

# Optional: Enable debug logging for development
DEBUG=true

# Demo agent setup (for Banking Bot mode)
AGENT_ALIAS_ID=Alias_ID_here
AGENT_ID=ID_here

# AWS AgentCore Configuration (REQUIRED for Banking Bot)
# Can also be configured via the GUI AWS Configuration panel
AGENT_CORE_RUNTIME_ARN=arn:aws:bedrock-agentcore:us-east-1:123456789012:runtime/BankingCoreRuntime_http_v1-abc123456

# LangFuse for monitoring
LANGFUSE_PUBLIC_KEY=pk-lf-
LANGFUSE_SECRET_KEY=sk-lf-
LANGFUSE_BASE_URL=https://cloud.langfuse.com

# ── SBC (SIP Session Border Controller) ──────────────────────────────────────
# Required only when running backend/dist/sbc/sbc-server.js
# The SBC bridges PSTN calls (via Amazon Chime SDK Voice Connector) to Nova Sonic.

# Public IP of the SBC host — advertised in SIP Contact and SDP c= lines
SBC_PUBLIC_IP=

# UDP port for SIP signalling (default 5060)
SBC_SIP_PORT=5060

# RTP port pool — supports SBC_RTP_PORT_COUNT/2 concurrent calls
SBC_RTP_PORT_BASE=10000
SBC_RTP_PORT_COUNT=200
